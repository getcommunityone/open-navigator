{
  "extends": "@canvas-commons/2d/tsconfig.project.json",
  "compilerOptions": {
    // canvas-commons 0.3.1 ships a few declaration files that trip strict
    // lib-checking (chroma-js types, project.d.ts export-assignment). They are
    // upstream issues, not ours, so skip type-checking of dependency .d.ts.
    "skipLibCheck": true
  },
  "include": ["src"]
}
