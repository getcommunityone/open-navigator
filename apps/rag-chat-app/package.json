{
  "author": "",
  "dependencies": {
    "@ai-sdk/openai": "^3.0.48",
    "@ai-sdk/react": "^3.0.140",
    "@databricks/appkit": "0.40.0",
    "@databricks/appkit-ui": "0.40.0",
    "@databricks/sdk-experimental": "0.17.0",
    "ai": "^6.0.138",
    "clsx": "2.1.1",
    "embla-carousel-react": "8.6.0",
    "lucide-react": "0.546.0",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "3.0.6",
    "react-router": "7.13.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "3.3.1",
    "tailwindcss-animate": "1.0.7",
    "tslib": "2.8.1",
    "tw-animate-css": "1.4.0",
    "zod": "4.1.13"
  },
  "description": "Streaming RAG chat app with pgvector retrieval and Lakebase-backed chat history",
  "devDependencies": {
    "@ast-grep/napi": "0.37.0",
    "@eslint/compat": "2.0.0",
    "@eslint/js": "9.39.1",
    "@tailwindcss/postcss": "4.1.17",
    "@tailwindcss/vite": "4.1.17",
    "@types/express": "5.0.5",
    "@types/node": "24.6.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@typescript-eslint/eslint-plugin": "8.48.0",
    "@typescript-eslint/parser": "8.48.0",
    "@vitejs/plugin-react": "5.0.4",
    "autoprefixer": "10.4.21",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "prettier": "3.6.2",
    "sharp": "0.34.5",
    "tailwindcss": "4.0.14",
    "tsdown": "0.20.3",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.0",
    "vite": "npm:rolldown-vite@7.1.14"
  },
  "keywords": [],
  "license": "Unlicensed",
  "main": "dist/server.js",
  "name": "rag-chat-app",
  "overrides": {
    "vite": "npm:rolldown-vite@7.1.14"
  },
  "scripts": {
    "build": "npm run build:server \u0026\u0026 npm run build:client",
    "build:client": "tsc -b tsconfig.client.json \u0026\u0026 vite build --config client/vite.config.ts",
    "build:server": "tsdown -c tsdown.server.config.ts",
    "clean": "rm -rf client/dist dist build node_modules",
    "deploy": "npm run sync:bundle-vars \u0026\u0026 databricks bundle deploy \u0026\u0026 databricks bundle run app",
    "dev": "NODE_ENV=development tsx watch --tsconfig ./tsconfig.server.json --env-file-if-exists=./.env ./server/server.ts",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:ast-grep": "appkit lint",
    "lint:fix": "eslint . --fix",
    "postinstall": "npm run typegen",
    "prebuild": "npm run sync \u0026\u0026 npm run typegen",
    "predev": "npm run sync \u0026\u0026 npm run typegen",
    "setup": "appkit setup --write",
    "start": "NODE_ENV=production node --env-file-if-exists=./.env ./dist/server.js",
    "sync": "appkit plugin sync --write --silent",
    "sync:bundle-vars": "node scripts/sync-bundle-vars.mjs",
    "typecheck": "tsc -p ./tsconfig.server.json --noEmit \u0026\u0026 tsc -p ./tsconfig.client.json --noEmit",
    "typegen": "appkit generate-types"
  },
  "type": "module",
  "version": "1.0.0"
}
