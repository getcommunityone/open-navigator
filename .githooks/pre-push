#!/bin/bash

# Pre-push Git hook to prevent broken builds from being pushed
# This runs quick build checks before allowing a push to remote

echo "🔍 Running pre-push checks..."
echo ""

FAILED=false

# Check 1: Frontend TypeScript
echo "📝 Checking web_app TypeScript..."
cd web_app
if ! npx tsc --noEmit 2>&1 | head -20; then
    echo "❌ TypeScript errors found in web_app/"
    FAILED=true
else
    echo "✅ Frontend TypeScript OK"
fi
cd ..
echo ""

# Check 2: Python syntax
echo "🐍 Checking Python syntax..."
if ! python -m py_compile main.py 2>&1; then
    echo "❌ Python syntax error in main.py"
    FAILED=true
else
    echo "✅ Python syntax OK"
fi
echo ""

# Check 3: Frontend build (quick check)
echo "🏗️  Testing web_app build..."
cd web_app
if ! npm run build > /dev/null 2>&1; then
    echo "❌ Frontend build failed"
    echo "Run 'cd web_app && npm run build' to see details"
    FAILED=true
else
    echo "✅ Frontend builds successfully"
fi
cd ..
echo ""

# Check 4: Jupyter notebooks - ensure no outputs committed
echo "📓 Checking Jupyter notebooks for outputs..."
NOTEBOOKS_WITH_OUTPUTS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.ipynb$' || true)

if [ -n "$NOTEBOOKS_WITH_OUTPUTS" ]; then
    # Check if any staged notebooks have outputs
    for nb in $NOTEBOOKS_WITH_OUTPUTS; do
        if [ -f "$nb" ]; then
            # Check if notebook has execution_count or outputs
            if grep -q '"execution_count": [0-9]' "$nb" || grep -q '"outputs": \[' "$nb"; then
                if grep -q '"outputs": \[\]' "$nb" > /dev/null 2>&1 && ! grep -q '"outputs": \[{' "$nb" > /dev/null 2>&1; then
                    # Notebook has empty outputs - OK
                    continue
                fi
                echo "⚠️  WARNING: $nb contains cell outputs"
                echo "   Run: python scripts/maintenance/clear_notebook_outputs.py $nb"
                FAILED=true
            fi
        fi
    done
    
    if [ "$FAILED" != true ]; then
        echo "✅ Notebooks are clean (no outputs)"
    fi
else
    echo "✓  No notebooks in this push"
fi
echo ""

if [ "$FAILED" = true ]; then
    echo ""
    echo "═══════════════════════════════════════════════════════════"
    echo "❌ PRE-PUSH CHECK FAILED"
    echo "═══════════════════════════════════════════════════════════"
    echo ""
    echo "Please fix the errors above before pushing."
    echo ""
    echo "To bypass this check (NOT recommended):"
    echo "  git push --no-verify"
    echo ""
    exit 1
fi

echo "═══════════════════════════════════════════════════════════"
echo "✅ All pre-push checks passed!"
echo "═══════════════════════════════════════════════════════════"
echo ""
exit 0
