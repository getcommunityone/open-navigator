# ---------------------------------------------------------------------
# Wikidata Query Service (WDQS) — load_jurisdictions_wikidata.py
# ---------------------------------------------------------------------
# WDQS is heavily throttled by Wikimedia per IP + User-Agent (~60s server
# query/min + burst / error-rate caps -> 429/502 cascades). Everything here
# is optional tuning; defaults live in code.
#
# May 2025 graph split: https://query.wikidata.org/ = **main** graph (places,
# gov, orgs). Scholarly-only: https://query-scholarly.wikidata.org/ . Legacy
# full graph (slow, transient): query-legacy-full.wikidata.org — see
# Wikidata:SPARQL_query_service/WDQS_graph_split
# WIKIDATA_SPARQL_GRAPH=main         # main (default jurisdictions) | scholarly | legacy_full
# WIKIDATA_SPARQL_ENDPOINT=          # overrides WIKIDATA_SPARQL_GRAPH when non-empty (e.g. https://query-scholarly.wikidata.org/sparql)
# Default WDQS URL is https://query.wikidata.org/sparql (main graph).
# WIKIDATA_SPARQL_MAX_GET_QUERY_CHARS=6000    # queries longer than this -> form-urlencoded POST
# WIKIDATA_SPARQL_TIMEOUT_SECONDS=180         # client read timeout; WDQS often needs 120–180 under load
# Set WIKIDATA_USER_AGENT to ProjectName/version (contact URL or email) — generic bots are deprioritized.
# WIKIDATA_FILTER_IN_LITERAL_CHUNK_SIZE=12    # literals per FILTER IN sub-query; smaller reduces timeouts (10–15)
# WIKIDATA_FILTER_IN_SUBQUERY_GAP_SECONDS=1   # pause between those sub-queries
#
# WDQS load is lowest ~midnight–06:00 UTC; busiest ~14:00–20:00 UTC — schedule heavy bulk loads off-peak.
# WIKIDATA_WIKIBASE_API_TIMEOUT_SECONDS=75    # wbgetentities / wbsearchentities only (default min(SPARQL,75s))
# WIKIDATA_WDQS_QUOTA_WINDOW_SECONDS=60        # sliding window used for pacing below
# WIKIDATA_WDQS_BUDGET_SECONDS_PER_WINDOW=50   # stay under Wikimedia rolling query-time cap (~60s/min + burst)
# WIKIDATA_WDQS_BUDGET_BURST_SECONDS=115
# WIKIDATA_WDQS_ERROR_WINDOW_SECONDS=60
# WIKIDATA_WDQS_ERROR_PAUSE_THRESHOLD=24      # this many WDQS failures in the window triggers cooldown
# WIKIDATA_WDQS_ERROR_STORM_PAUSE_SECONDS=90
#
# WIKIDATA_INCREMENTAL_MERGE=1     # default ON: keep existing QIDs; WDQS only for NULL wikidata_id. 0 = DELETE+re-seed each run (slow).
# WIKIDATA_PRIORITY_STATES_SKIP_COMPLETE=1  # default ON (--priority-states only): skip already-enriched USPS. 0 = always attempt all six.
#
# "Happy path" (avoid 429 / stay within WDQS budget — backfill stragglers later):
#   export WIKIDATA_HAPPY_PATH=1
#   … or:  .venv/bin/python packages/scrapers/src/scrapers/wikidata/load_jurisdictions_wikidata.py --happy-path --priority-states --types county
#   … or:  ./packages/scrapers/src/scrapers/wikidata/run_wikidata_happy_path.sh --priority-states --types county,city
# Fills only-unset keys with: Retry-After cap 120s, throttle 12s, task sleep 8s,
# WIKIDATA_HYBRID_ENRICH=1 (bulk id->Q, not legacy FILTER batches), incremental merge,
# priority skip-complete, county-gap off, muni/school bulk WITHOUT FILTER supplement, NO county
# entity-search fallback, chunk sleep 3s. Override any key in .env as usual.
# Backfill: unset WIKIDATA_HAPPY_PATH and set e.g. WIKIDATA_MUNICIPALITY_BULK_SUPPLEMENT_SPARQL=1,
# WIKIDATA_COUNTY_BULK_FALLBACK_ENTITY_SEARCH=1, or WIKIDATA_LOAD_RETRY_COUNTY_GAPS=1 for gap states.
# WIKIDATA_CACHE_DIR=data/cache/wikidata   # SPARQL response JSON cache (hybrid mode also writes geography_qid_mapping_v1.json here)
# WIKIDATA_CACHE_TTL_SECONDS=604800        # 7d default; extend to reuse file cache longer between runs
#
# Hybrid enrichment (recommended when WDQS times out): narrow WDQS to id->item (P774/P590/P882/P6545…), hydrate via wbgetentities
# WIKIDATA_HYBRID_ENRICH=1
# County id->Q: bulk_state = one WDQS query per state (P131=state + types), match FIPS in memory (default). entity_search = slow per-county API. sparql = FILTER IN batches.
# WIKIDATA_HYBRID_COUNTY_MAP_MODE=bulk_state
# WIKIDATA_COUNTY_BULK_STATE_LIMIT=600       # max rows from bulk query (~Texas counties + headroom)
# WIKIDATA_COUNTY_BULK_FALLBACK_ENTITY_SEARCH=1   # if bulk WDQS misses a GEOID, try entity-search for that row only
# Municipality mapping WDQS (supplement): property-led P774/P590 + small FILTER IN sub-queries. Hybrid hydrates via wbgetentities.
# WIKIDATA_HYBRID_MUNICIPALITY_MAP_MODE=bulk_state
# WIKIDATA_MUNICIPALITY_BULK_STATE_LIMIT=8000
# WIKIDATA_MUNICIPALITY_BULK_SUPPLEMENT_SPARQL=0   # default OFF; set 1 only as a backfill pass when WDQS is quiet
# WIKIDATA_MUNICIPALITY_SPARQL_WHEN_BULK_EMPTY=1  # if bulk WDQS returns 0 rows, fall back to heavy per-chunk FILTER (default 1; happy path sets 0)
# WIKIDATA_MUNICIPALITY_SUPPLEMENT_SPLIT_WDQS=1   # split 2nd-step FILTER into FIPS-only + GNIS-only (default 1; reduces WDQS 500)
# WIKIDATA_MUNICIPALITY_PRE_BULK_WDQS_PAUSE_SECONDS=30  # pause before the one state bulk municipality WDQS call (happy path 30)
# WIKIDATA_MUNICIPALITY_POST_BULK_WDQS_GAP_SECONDS=10   # pause after bulk WDQS before first FILTER supplement
# WIKIDATA_MUNICIPALITY_FILTER_WDQS_GAP_SECONDS=6     # pause before each municipality FILTER IN WDQS call
# WIKIDATA_HYBRID_SCHOOL_MAP_MODE=bulk_state
# WIKIDATA_SCHOOL_BULK_STATE_LIMIT=2500
# WIKIDATA_SCHOOL_BULK_SUPPLEMENT_SPARQL=0   # default OFF; set 1 only as a backfill pass when WDQS is quiet
# WIKIDATA_SCHOOL_POST_BULK_WDQS_GAP_SECONDS=10
# WIKIDATA_SCHOOL_FILTER_WDQS_GAP_SECONDS=6
# US state row: optional batched wbgetentities for all STATE_MAP Q-ids on first state task (opt-in; helps full-US sweeps).
# WIKIDATA_STATE_BULK_WBGETENTITIES=0
# WIKIDATA_QID_CACHE_WARM_DB=1       # merge existing Postgres *_wikidata QIDs into the cache JSON before each state's hybrid run
# WIKIDATA_ENRICH_USE_PYWIKIBOT=1     # optional: ItemPage hydration via pywikibot instead of REST (needs pip install pywikibot)
# WIKIDATA_STATE_LEGACY_SPARQL=1      # use WDQS + label service for US state row; default is Wikibase wbgetentities
# JURISDICTION_DISCOVERY_YOUTUBE_TIMEOUT_SECONDS=90  # per-place cap on YouTube discovery (0 = no cap)
# WIKIDATA_DISCOVERY_ENRICH_TIMEOUT_SECONDS=60  # per-place cap on Step 7 Wikidata in jurisdiction discovery (0 = no cap)
# WIKIDATA_THROTTLE_SECONDS=6      # minimum seconds between WDQS requests (per process lock)
# WIKIDATA_RETRY_AFTER_MAX_SECONDS=120   # cap 429 Retry-After (WDQS often sends ~1000s; <=0 is coerced to 120 in code)
# --- Egress for WDQS + w/api.php only (optional; not generic HTTP_PROXY for your whole OS) ---
# Docker WARP (typical): this repo does NOT start WARP for you. Run a WARP/SOCKS container that publishes
# SOCKS5 on the host, then point the loader at it:
#   WIKIDATA_HTTPS_PROXY=socks5://127.0.0.1:1080
# Run the loader where localhost:1080 is reachable (host terminal, or host.docker.internal:1080 inside Compose).
# Startup logs print `proxy enabled -> 'socks5://…'` when set.
# Quick test:
#   curl -sS -o /dev/null -w "%{http_code}\n" --proxy socks5h://127.0.0.1:1080 "https://query.wikidata.org/sparql?query=SELECT%20%3Fx%20WHERE%20%7B%20%3Fx%20%3Fp%20%3Fo%20%7D%20LIMIT%201"
# Expect 200 or 429 (both mean the tunnel reached WDQS). Refused/timeout -> SOCKS not up or wrong port.
# Cloudflare WARP desktop app (1.1.1.1): turn Connected on if you use that instead; no WIKIDATA_* flag controls the GUI.
# WIKIDATA_CONNECT_RETRY_BASE_SECONDS=10   # exponential backoff base for TCP connect failures to WDQS
# WIKIDATA_CONNECT_RETRY_MAX_SECONDS=300    # max seconds per connect-retry wait
# WIKIDATA_SPARQL_MAX_ATTEMPTS=10          # retries per query
# WIKIDATA_TASK_SLEEP_SECONDS=2   # pause between jurisdiction tasks in load_jurisdictions_wikidata.py
#
# County SPARQL default: FIPS-batched queries from bronze GEIDs (skips expensive P131+ across the state).
# WIKIDATA_COUNTY_LEGACY_STATE_QUERY=0   # force old P131+ one-query-per-state behavior
# WIKIDATA_COUNTY_FIPS_BATCH=1          # unset or 1 = batches; 0 with no legacy flag = fall back to legacy
# WIKIDATA_COUNTY_CHUNK_SIZE=35         # GEOIDs per WDQS chunk (5–120)
# WIKIDATA_COUNTY_CHUNK_SLEEP_SECONDS=1 # pause between county chunks (same process; eases 429/timeout)
#
# Municipality + schooldistrict SPARQL (same pacing env as counties)
# WIKIDATA_CITY_IDENTIFIER_BATCH=1          # bronze geoid/GNIS -> P774+P590 FILTER batches (skip P131+)
# WIKIDATA_CITY_LEGACY_STATE_QUERY=0       # force old single-state P131+ crawl + LIMIT 2000
# WIKIDATA_CITY_CHUNK_SIZE=25               # GEOID rows per batch (5–150)
# WIKIDATA_MUNICIPALITY_FLUSH_DB_EACH_CHUNK=1   # hybrid municipalities: commit bronze after each chunk (default 1)
#
# WIKIDATA_SCHOOL_IDENTIFIER_BATCH=1       # bronze NCES/GEOID chunks (no P131+, no superintendent sub-query)
# WIKIDATA_SCHOOL_LEGACY_STATE_QUERY=1      # superintendent + P131+ (slow/timeouts likely)
# WIKIDATA_SCHOOL_CHUNK_SIZE=35             # district GEOIDs per batch (5–200)
#
# Jurisdictions loader — run ./packages/scrapers/src/scrapers/wikidata/run_load_jurisdictions_wikidata.sh
# WIKIDATA_LOAD_RETRY_COUNTY_GAPS=1      # rerun county task only where rows < base OR enriched < base (clears checkpoint per USPS)
# WIKIDATA_LOAD_ALL_US_STATES=0           # full US sweep (ignored when RETRY_COUNTY_GAPS=1)
# WIKIDATA_LOAD_PRIORITY_STATES=1        # CLI --priority-states default on (AL,GA,IN,MA,WA,WI)
# WIKIDATA_LOAD_TYPES=city,county,state,school_district   # loader default unless you shrink it
# WIKIDATA_LOAD_CHECKPOINT_FILE=    # default: <WIKIDATA_CACHE_DIR>/wikidata_jurisdictions_checkpoint.json
# WIKIDATA_LOAD_FORCE=0                  # set 1 to ignore checkpoint (--no-force on CLI to override env)
# WIKIDATA_LOAD_STATES=AL,TX,OH           # explicit list when no ALL / PRIORITY / RETRY_GAP mode
# WIKIDATA_USER_AGENT="..."        # single UA when WIKIDATA_USER_AGENT_POOL is empty
# WIKIDATA_USER_AGENT_POOL="UA1###UA2###UA3"   # separate UAs with ### (commas appear inside each UA); rotates per WDQS request
# WIKIDATA_LOG_UA_STATS=1            # defaults ON when USER_AGENT_POOL is set; WDQS summaries in logs
# WIKIDATA_UA_STATS_LOG_EVERY_NET=10  # emit summary every N completed WDQS calls (HTTP 200)
# WIKIDATA_HTTP_KEEPALIVE=1          # optional; default off — avoids RemoteProtocolError after long throttles/VPN

# ---------------------------------------------------------------------
# YouTube transcripts (load_youtube_events_to_postgres.py)
# ---------------------------------------------------------------------
# Webshare rotating residential (caption API via youtube-transcript-api):
#   https://dashboard.webshare.io/proxy/settings -> Proxy Username + Proxy Password
# Do NOT use the per-IP password from the proxy list table.
# Quote passwords with @ or # :  PROXY_PASSWORD='your-secret'
# PROXY_USER_NAME=
# PROXY_PASSWORD=
# WEBSHARE_FILTER_IP_LOCATIONS=us,gb,de,es,pl,jp
# YOUTUBE_USE_WEBSHARE=0             # no Webshare: caption API + yt-dlp use direct egress (+ cookies)
# NO_TOMBSTONES=1                    # run_priority_states_last_n.sh -> --no-tombstones on caption backfill
# N=10                               # run_priority_states_last_n.sh — newest videos per jurisdiction
# Verify: .venv/bin/python packages/scrapers/src/scrapers/youtube/verify_webshare_proxy.py
# HTTP 407 = wrong PROXY_PASSWORD (or username). Not a YouTube block.
# YOUTUBE_TRANSCRIPT_PROXY=          # optional generic HTTP/SOCKS instead of Webshare
# YOUTUBE_HTTPS_PROXY=               # yt-dlp only (catalog); leave unset for direct egress
# YOUTUBE_YTDLP_USE_WEBSHARE=0       # opt out: yt-dlp direct egress even when PROXY_* is set
#
# Authenticate via cookies over direct egress (Webshare as manual fallback only).
# YOUTUBE_COOKIES_FILE=youtube_cookies.txt
# TRANSCRIPT_SOURCE=auto              # auto | db | disk | youtube
# WEBSHARE_RETRIES_WHEN_BLOCKED=2     # fail fast when the proxy pool is exhausted/unreachable
# WORKERS=1
# TRANSCRIPT_WORKERS=1
# TRANSCRIPT_DELAY=25                 # seconds between transcript fetches
# Google Meet login (gomeet scraper)
# GOMEET_LOGIN_EMAIL=your_email@example.com

# ---------------------------------------------------------------------
# Gemma hackathon pipeline (Colab + local Jupyter)
# ---------------------------------------------------------------------
# WSL equivalent of G:\My Drive\CommunityOne\hackathons\2026_Gemma_4_Good
# Mount G: in WSL first:  bash packages/llm/src/llm/governance/mount_drive.sh
# LOG_GDRIVE_MOUNT=/mnt/g/My Drive
# GOVERNANCE_PIPELINE_DATA_ROOT=/mnt/g/My Drive/CommunityOne/hackathons/2026_Gemma_4_Good
# Optional: override raw PDFs folder only (default: <pipeline root>/01_raw_inputs)
# GOVERNANCE_RAW_INPUTS_ROOT=/mnt/g/My Drive/CommunityOne/hackathons/2026_Gemma_4_Good/01_raw_inputs
# Do not use the full scraped_meetings cache unless you opt in:
# GOVERNANCE_USE_SCRAPED_CACHE_FALLBACK=1
