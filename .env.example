# =====================================================================
# Open Navigator — Environment Configuration
# =====================================================================
# Copy this file to `.env` and fill in values as needed. It is organized
# in tiers so you only set what you actually use:
#
#   1. MINIMUM LOCAL DEV ........ required to boot the site locally
#   2. OPTIONAL FOR LOCAL ....... login, analytics, bills (site runs without)
#   3. DATA-SOURCE API KEYS ..... only for running ingestion pipelines
#   4. DEPLOYMENT ............... HuggingFace / Neon prod / Databricks
#   5. ADVANCED TUNING .......... Wikidata, YouTube transcripts, agents, misc.
#
# The three local services (launch all three with ./start-all.sh):
#   * API   (FastAPI)        -> http://localhost:8000
#   * Web   (React + Vite)   -> http://localhost:5173
#   * Docs  (Docusaurus)     -> http://localhost:3000
# =====================================================================


# =====================================================================
# 1. MINIMUM LOCAL DEV  (required)
# =====================================================================
# This is the ONLY variable the site needs to run locally.
#
# The API reads it for BOTH the civic-data warehouse AND the auth/user
# tables. It is the top of the DSN priority chain:
#   NEON_DATABASE_URL_DEV  ->  NEON_DATABASE_URL  ->  DATABASE_URL  ->  sqlite
#
# Point it at the already-running local Postgres warehouse on port 5433,
# database `open_navigator` (see CLAUDE.md -> Database Access). Do NOT start
# a new Docker Postgres — it is already running.
NEON_DATABASE_URL_DEV=postgresql://postgres:password@localhost:5433/open_navigator

# Data schema the API serves. `public` (PII-light serving views) is the
# default and the correct choice for local dev. Set `gold` only for a
# private/internal instance that needs the full un-redacted warehouse.
# API_DB_SCHEMA=public

# The web app (5173) and docs (3000) need NO env vars to boot.
# The web app proxies the API at `/api` by default; override only if your
# API runs elsewhere.
# VITE_API_URL=api


# =====================================================================
# 2. OPTIONAL FOR LOCAL  (site runs fine without these)
# =====================================================================

# --- JWT signing ------------------------------------------------------
# Auto-generated on startup if unset (logins won't survive a restart).
# Set a fixed value for deterministic JWT validation across restarts.
# Generate with: openssl rand -hex 32
# JWT_SECRET_KEY=your_random_secret_key_here_min_32_chars

# --- OAuth login (optional) ------------------------------------------
# The site boots and serves all unauthenticated endpoints without these.
# Each provider's login endpoint returns an error only if you try it with
# its credentials missing. See web_docs/docs/deployment/authentication-setup.md
#
# Frontend URL — where to redirect after OAuth.
#   Local dev (separate servers): http://localhost:5173
#   Same-domain deploy: leave blank or https://www.communityone.com
FRONTEND_URL=http://localhost:5173
# API base URL — used to build OAuth callback URLs.
API_BASE_URL=http://localhost:8000
#
# HuggingFace OAuth (https://huggingface.co/settings/applications)
#   Redirect URI (dev):  http://localhost:8000/api/auth/callback/huggingface
# HUGGINGFACE_CLIENT_ID=your_hf_client_id
# HUGGINGFACE_CLIENT_SECRET=your_hf_client_secret
#
# Google OAuth (https://console.cloud.google.com/apis/credentials)
#   Redirect URI (dev):  http://localhost:8000/api/auth/callback/google
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
#
# Facebook OAuth (https://developers.facebook.com/apps)
#   Redirect URI (dev):  http://localhost:8000/api/auth/callback/facebook
# FACEBOOK_APP_ID=your_facebook_app_id
# FACEBOOK_APP_SECRET=your_facebook_app_secret
#
# GitHub OAuth (https://github.com/settings/developers)
#   Redirect URI (dev):  http://localhost:8000/api/auth/callback/github
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret
#
# GitHub API token — only for the in-app contact form (creates issues).
# Needs `repo` scope. https://github.com/settings/tokens
# GITHUB_TOKEN=your_github_personal_access_token
# GITHUB_REPO=getcommunityone/open-navigator

# --- Bills / legislative data (optional) -----------------------------
# Only needed for bill/legislator/vote features. Restore the Open States
# dump into a local `openstates` database first:
#   1. python scripts/bulk_legislative_download.py --postgres --month 2026-04
#   2. createdb openstates
#   3. pg_restore --dbname=openstates --no-owner \
#        data/cache/legislation_bulk/postgres/2026-04-public.pgdump
# OPENSTATES_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/openstates

# --- Analytics (optional) --------------------------------------------
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX).
# Without it the site runs; analytics simply don't load.
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# --- Local server / logging knobs (optional) -------------------------
# API_HOST=0.0.0.0
# API_PORT=8000
# API_WORKERS=4
# LOG_LEVEL=INFO
# LOG_FILE=logs/open-navigator.log
# Pager for psql / CLI output ('cat' on Unix, 'type' on Windows)
PAGER=cat

# --- Alternative DB layouts (advanced) -------------------------------
# The chain above already covers local dev. These exist for other setups:
#
# Raw Postgres parts (used by some loaders that build a DSN piecemeal):
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5433
#
# DATABASE_URL — backwards-compatible fallback (only used if the NEON_*
# vars are unset). SQLite needs no setup but serves no civic data:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/open_navigator
# DATABASE_URL=sqlite:///./data/users.db
#
# Force ALL Python loaders to a single Postgres URL (overrides NEON_* when set):
# OPEN_NAVIGATOR_DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require


