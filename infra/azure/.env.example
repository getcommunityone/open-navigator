# Azure auth for Terraform — copy to infra/azure/.env (gitignored) and fill in.
# The azurerm provider AND the azurerm state backend both read these automatically.
# `source` this file (or use direnv / `dotenvx run`) before running terraform.
#
#   set -a && source .env && set +a
#   terraform plan
#
# ── Billing scope (kept out of git; subscription naming lives in the tracked
#    subscriptions.auto.tfvars). TF_VAR_ prefix feeds terraform's billing_scope_id.
#    Find it: az billing invoice-section list --account-name <ba> --profile-name <bp> -o table
#    MCA format shown; use the EA/MPA format if that's your agreement. ──────────────
export TF_VAR_billing_scope_id="/providers/Microsoft.Billing/billingAccounts/00000000-0000-0000-0000-000000000000:00000000-0000-0000-0000-000000000000_2019-05-31/billingProfiles/AAAA-BBBB-CCC-DDD/invoiceSections/EEEE-FFFF-GGG-HHH"

# ── Required for all auth methods ──────────────────────────────────────────────
export ARM_TENANT_ID="00000000-0000-0000-0000-000000000000"
# Any existing subscription the service principal can authenticate against.
# (Subscription CREATION happens at billing scope, but the provider still needs
#  a subscription context to initialise.)
export ARM_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
export ARM_CLIENT_ID="00000000-0000-0000-0000-000000000000"

# ── Option A: client secret (simplest) ────────────────────────────────────────
export ARM_CLIENT_SECRET="REPLACE_ME"

# ── Option B: OIDC / workload identity federation (PREFERRED — no secret) ──────
# Comment out ARM_CLIENT_SECRET above and use these instead:
# export ARM_USE_OIDC="true"
# export ARM_OIDC_TOKEN_FILE_PATH="/var/run/secrets/azure/tokens/azure-identity-token"
#
# The service principal needs the "Owner" or a custom role on the BILLING SCOPE
# (e.g. MCA invoice section) plus "Management Group Contributor" if associating MGs.
