{
  "name": "open-navigator-ui",
  "version": "1.0.0",
  "description": "CommunityOne: The open path to everything local",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "gen:api:schema": "python ../scripts/frontend/export_openapi.py --out openapi.json",
    "gen:api:types": "openapi-typescript openapi.json --output src/lib/api.types.ts",
    "gen:api": "npm run gen:api:schema && npm run gen:api:types"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.0.18",
    "@tanstack/react-query": "^5.14.2",
    "clsx": "^2.0.0",
    "d3-geo": "^3.1.1",
    "d3-interpolate": "^3.0.1",
    "d3-selection": "^3.0.0",
    "d3-transition": "^3.0.1",
    "d3-zoom": "^3.0.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^11.18.2",
    "leaflet": "^1.9.4",
    "openapi-fetch": "^0.17.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-query": "^3.39.3",
    "react-router-dom": "^6.20.0",
    "react-select": "^5.10.2",
    "react-simple-maps": "^3.0.0",
    "recharts": "^2.10.3",
    "topojson-client": "^3.1.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/leaflet": "^1.9.8",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^8.0.16"
  }
}
